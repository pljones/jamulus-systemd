JAMULUS_PORT=22624
#JAMULUS_DISCONNECT=false
#JAMULUS_MULTITHREADED=false
#JAMULUS_FASTUPDATE=false
#JAMULUS_DELAYPAN=true
#JAMULUS_IPV6=false
#JAMULUS_NOIPV6=true
JAMULUS_MAXCHANS=1
#JAMULUS_QOS=
#JAMULUS_BINDIP=
JAMULUS_LOGFILE=/opt/Jamulus/log/Directory6.log
JAMULUS_DIRECTORY=localhost
#JAMULUS_PUBLICIP=81.174.155.168
JAMULUS_FILTER=[3.8.0]
JAMULUS_DIRECTORYFILE=/opt/Jamulus/run/Directory6.persistence
#JAMULUS_ENABLE_RECORDING=false
#JAMULUS_RECORDING_DIR=
#JAMULUS_RECORDING_OFF=false
#JAMULUS_ACCEPT_LICENCE=false
JAMULUS_SERVERINFO='Directory on 22624;London;224'
JAMULUS_WELCOMEMSG='<h3>Directory on 22624</h3><p>Server list hosted by drealm.info.</p><p><b>SINGLE CLIENT DIRECTORY</b> - you will be alone here.</p>'
#JAMULUS_JSONRPCPORT=
#JAMULUS_JSONRPCSECRET=
